## Backend API base (recommended: host only; /api/v1 is appended automatically)
# EXPO_PUBLIC_API_BASE_URL=https://api.yourdomain.com

## Force local mock auth (optional)
# EXPO_PUBLIC_USE_MOCK_AUTH=true

## Licensing endpoints (optional overrides; default to /licenses/me and /licenses/activate)
# EXPO_PUBLIC_LICENSE_STATUS_PATH=/licenses/me
# EXPO_PUBLIC_LICENSE_ACTIVATE_PATH=/licenses/activate

## RevenueCat (native only)
# Set test-store values first, then replace with production values later.
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_...
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
# EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default
# EXPO_PUBLIC_REVENUECAT_PACKAGE_ID=\$rc_annual
# EXPO_PUBLIC_REVENUECAT_PRODUCT_IDS=com.wtt.healthage.pro.yearly,com.wtt.healthage.pro.yearly.android
# Optional: app -> backend sync endpoint for RevenueCat status snapshots
# EXPO_PUBLIC_REVENUECAT_SYNC_PATH=/licenses/revenuecat/sync

## Web payments (optional; if your backend exposes Stripe checkout)
# EXPO_PUBLIC_STRIPE_CHECKOUT_PATH=/stripe/checkout
# EXPO_PUBLIC_STRIPE_PORTAL_PATH=/stripe/portal
