{
  "name": "healthage",
  "description": "Health Age desktop app",
  "author": "Wisdom Tooth Technologies",
  "license": "0BSD",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "electron": "electron electron/main.cjs",
    "electron:preview": "npm run build:web && electron electron/main.cjs",
    "dist:win:dir": "npm run build:web && electron-builder --win dir --x64",
    "dist:win": "npm run build:web && electron-builder --win nsis --x64",
    "dist:win:arm64": "npm run build:web && electron-builder --win nsis --arm64",
    "dist:win:store": "npm run build:web && electron-builder --win appx --x64",
    "dist:win:store:arm64": "npm run build:web && electron-builder --win appx --arm64",
    "dist:win:all": "npm run build:web && electron-builder --win nsis appx --x64"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.2.1",
    "@react-navigation/drawer": "^7.1.2",
    "@react-navigation/native": "^7.0.15",
    "@react-navigation/stack": "^7.1.2",
    "autoprefixer": "^10.4.21",
    "docx": "^9.3.0",
    "expo": "~53.0.27",
    "expo-apple-authentication": "~7.2.4",
    "expo-build-properties": "~0.14.8",
    "expo-crypto": "~14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-localization": "~16.1.6",
    "expo-media-library": "~17.1.7",
    "expo-print": "~14.1.4",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "html-to-docx": "^1.8.0",
    "i18next": "^24.2.2",
    "lucide-react-native": "^1.14.0",
    "pdf-lib": "^1.17.1",
    "postcss-cli": "^11.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^15.4.1",
    "react-native": "0.79.6",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-html-to-pdf": "^0.12.0",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-purchases": "9.15.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-share": "^12.0.9",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "react-native-wheel-picker-expo": "^0.5.4",
    "read-excel-file": "^5.8.7",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.0.10",
    "@types/react-native-html-to-pdf": "^0.8.3",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.3"
  },
  "private": true,
  "build": {
    "appId": "com.wtt.healthage",
    "productName": "Health Age",
    "copyright": "Copyright © 2026 Wisdom Tooth Technologies",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/healthAge_Icon.png",
      "package.json",
      "!node_modules/**/*"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "extraMetadata": {
      "main": "electron/main.cjs",
      "dependencies": {},
      "devDependencies": {}
    },
    "win": {
      "icon": "assets/healthAge_Icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Health Age"
    },
    "appx": {
      "applicationId": "HealthAge",
      "backgroundColor": "#ffffff",
      "displayName": "Health Age",
      "identityName": "REPLACE_WITH_PARTNER_CENTER_PACKAGE_IDENTITY_NAME",
      "publisher": "CN=REPLACE_WITH_PUBLISHER_ID",
      "publisherDisplayName": "Wisdom Tooth Technologies"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "autoprefixer",
          "docx",
          "html-to-docx",
          "pdf-lib",
          "postcss-cli",
          "react-native-wheel-picker-expo",
          "read-excel-file",
          "uuid",
          "xlsx",
          "react-native-fs",
          "react-native-html-to-pdf"
        ]
      }
    }
  }
}
