{
  "expo": {
    "name": "Health Age",
    "slug": "healthAge",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/healthAge_Icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/logo.png",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.wtt.healthAge",
      "usesAppleSignIn": true,
      "supportsTablet": true
    },
    "android": {
      "versionCode": 10,
      "permissions": [
        "com.android.vending.BILLING",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/healthAge_Adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.wtt.healthAge"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-sqlite",
      "expo-build-properties"
    ],
    "extra": {
      "eas": {
        "projectId": "3684707d-6c10-4127-9a5d-39b86daccc93"
      }
    }
  }
}
