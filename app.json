{
  "expo": {
    "name": "Health Age",
    "slug": "healthAge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/healthAge_Icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/logo.png",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.wtt.healthAge",
      "buildNumber": "13",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Health Age needs photo library access so you can choose images to attach in your profile and reports.",
        "NSPhotoLibraryAddUsageDescription": "Health Age needs permission to save generated health reports and exported files to your photo library when you choose to save them."
      }
    },
    "android": {
      "versionCode": 11,
      "permissions": [
        "com.android.vending.BILLING",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/healthAge_Adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.wtt.healthAge"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "./plugins/withIosNoMacCatalyst"
    ],
    "extra": {
      "eas": {
        "projectId": "3684707d-6c10-4127-9a5d-39b86daccc93"
      }
    }
  }
}
